# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=true
LOG_LEVEL=DEBUG

# ── GitHub App ────────────────────────────────────────────────────────────────
# Create a GitHub App at https://github.com/settings/apps
GITHUB_APP_ID=your_github_app_id
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.1

# ── LangChain (optional tracing) ──────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=code-review-bot

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# ── Review Settings ───────────────────────────────────────────────────────────
MAX_FILES_PER_PR=50
MAX_DIFF_LINES=2000
MIN_SEVERITY_TO_BLOCK=HIGH    # LOW | MEDIUM | HIGH | CRITICAL

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_SECURITY_CHECKS=true
ENABLE_PERFORMANCE_CHECKS=true
ENABLE_STYLE_CHECKS=true
ENABLE_PR_SUMMARY=true
AUTO_APPROVE_MINOR=false

# ── Local ngrok (for webhook testing) ────────────────────────────────────────
NGROK_AUTHTOKEN=
